<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Go2TravelPlanner</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #f9fafb;
      color: #333;
    }

    /* Navbar */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 40px;
      background: #fff;
      border-bottom: 1px solid #eee;
    }

    .logo {
      font-weight: bold;
      color: #1da1a2;
      font-size: 18px;
    }

    .nav-links a {
      margin: 0 15px;
      text-decoration: none;
      color: #555;
      font-size: 14px;
    }

    .nav-links a:hover {
      color: #1da1a2;
    }

    /* Hero Section */
    .hero {
      text-align: center;
      padding: 100px 20px;
    }

    .hero h1 {
      font-size: 40px;
      margin-bottom: 15px;
    }

    .hero p {
      color: #777;
      max-width: 600px;
      margin: 0 auto 30px;
    }

    /* Buttons */
    .btn {
      padding: 12px 25px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-size: 14px;
      margin: 5px;
    }

    .btn-primary {
      background-color: #1da1a2;
      color: white;
    }

    .btn-secondary {
      background-color: #fff;
      border: 1px solid #ccc;
      color: #333;
    }

    /* Section */
    .section {
      text-align: center;
      padding: 80px 20px;
    }

    .section h2 {
      margin-bottom: 10px;
    }

    .section p {
      color: #777;
    }

    /* Floating button */
    .floating-btn {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: #1da1a2;
      color: white;
      padding: 15px;
      border-radius: 50%;
      font-size: 18px;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <div class="navbar">
    <div class="logo">Go2TravelPlanner</div>
    <div class="nav-links">
      <a href="#">Home</a>
      <a href="#">Cities</a>
      <a href="#">Daily Activities</a>
      <a href="#">My Trips</a>
      <a href="#">Login</a>
    </div>
  </div>

  <!-- Hero Section -->
  <div class="hero">
    <h1>Plan Your Dream Journey</h1>
    <p>
      Discover amazing destinations, organize your daily activities,
      and create unforgettable travel experiences with our intuitive trip planner.
    </p>

    <button class="btn btn-primary">Start Exploring →</button>
    <button class="btn btn-secondary">My Trips</button>
  </div>

  <!-- Info Section -->
  <div class="section">
    <h2>Everything You Need to Plan</h2>
    <p>All the tools you need to create the perfect itinerary</p>
  </div>

  <!-- Floating Button -->
  <div class="floating-btn">☰</div>

</body>
</html>